{
    "openapi": "3.1.0",
    "info": {
        "title": "TenderHack Backend",
        "description": "Backend template for a distributed monolith architecture.",
        "version": "0.1.0"
    },
    "paths": {
        "/health": {
            "get": {
                "tags": [
                    "system"
                ],
                "summary": "Application healthcheck",
                "operationId": "healthcheck_health_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "additionalProperties": {
                                        "type": "string"
                                    },
                                    "type": "object",
                                    "title": "Response Healthcheck Health Get"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/health": {
            "get": {
                "tags": [
                    "system"
                ],
                "summary": "Service healthcheck",
                "operationId": "healthcheck_api_v1_health_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "additionalProperties": {
                                        "type": "string"
                                    },
                                    "type": "object",
                                    "title": "Response Healthcheck Api V1 Health Get"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/auth/login": {
            "post": {
                "tags": [
                    "auth",
                    "auth"
                ],
                "summary": "Authenticate user and issue access token",
                "operationId": "login_api_v1_auth_login_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TokenResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/auth/me": {
            "get": {
                "tags": [
                    "auth",
                    "auth"
                ],
                "summary": "Return current authenticated user",
                "operationId": "me_api_v1_auth_me_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "HTTPBearer": []
                    }
                ]
            }
        },
        "/api/v1/parsing/jobs": {
            "post": {
                "tags": [
                    "parsing",
                    "parsing"
                ],
                "summary": "Create parsing job",
                "operationId": "create_parse_job_api_v1_parsing_jobs_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ParseJobRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ParseJobResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/llm/embed": {
            "post": {
                "tags": [
                    "llm",
                    "llm"
                ],
                "summary": "Get text embedding via Ollama",
                "operationId": "embed_text_api_v1_llm_embed_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/EmbedRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EmbedResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/llm/embed/batch": {
            "post": {
                "tags": [
                    "llm",
                    "llm"
                ],
                "summary": "Get batch text embeddings via Ollama",
                "operationId": "embed_batch_api_v1_llm_embed_batch_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/EmbedBatchRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EmbedBatchResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/cte/{cte_id}": {
            "get": {
                "tags": [
                    "cte",
                    "cte"
                ],
                "summary": "Get CTE by ID",
                "operationId": "get_cte_by_id_api_v1_cte__cte_id__get",
                "parameters": [
                    {
                        "name": "cte_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "title": "Cte Id"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CteItem"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/generate_doc": {
            "post": {
                "tags": [
                    "generate_doc",
                    "generate_doc"
                ],
                "summary": "Generate NMCK document",
                "operationId": "generate_doc_api_v1_generate_doc_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/GenerateDocRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response"
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "CteItem": {
                "properties": {
                    "cte_id": {
                        "type": "string",
                        "title": "Cte Id"
                    },
                    "category": {
                        "type": "string",
                        "title": "Category"
                    },
                    "manufacturer": {
                        "type": "string",
                        "title": "Manufacturer"
                    },
                    "description": {
                        "type": "string",
                        "title": "Description"
                    },
                    "price": {
                        "anyOf": [
                            {
                                "type": "string",
                                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Price"
                    },
                    "price_normalized": {
                        "anyOf": [
                            {
                                "type": "string",
                                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Price Normalized"
                    },
                    "region": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Region"
                    },
                    "characteristics": {
                        "anyOf": [
                            {
                                "additionalProperties": true,
                                "type": "object"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Characteristics"
                    }
                },
                "type": "object",
                "required": [
                    "cte_id",
                    "category",
                    "manufacturer",
                    "description",
                    "price",
                    "price_normalized",
                    "region",
                    "characteristics"
                ],
                "title": "CteItem"
            },
            "DocumentSource": {
                "properties": {
                    "name": {
                        "type": "string",
                        "title": "Name"
                    },
                    "supplier": {
                        "type": "string",
                        "title": "Supplier"
                    },
                    "price": {
                        "type": "number",
                        "title": "Price"
                    },
                    "date": {
                        "type": "string",
                        "title": "Date"
                    }
                },
                "type": "object",
                "required": [
                    "name",
                    "supplier",
                    "price",
                    "date"
                ],
                "title": "DocumentSource"
            },
            "EmbedBatchRequest": {
                "properties": {
                    "texts": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "minItems": 1,
                        "title": "Texts"
                    }
                },
                "type": "object",
                "required": [
                    "texts"
                ],
                "title": "EmbedBatchRequest"
            },
            "EmbedBatchResponse": {
                "properties": {
                    "model": {
                        "type": "string",
                        "title": "Model"
                    },
                    "embeddings": {
                        "items": {
                            "items": {
                                "type": "number"
                            },
                            "type": "array"
                        },
                        "type": "array",
                        "title": "Embeddings"
                    }
                },
                "type": "object",
                "required": [
                    "model",
                    "embeddings"
                ],
                "title": "EmbedBatchResponse"
            },
            "EmbedRequest": {
                "properties": {
                    "text": {
                        "type": "string",
                        "minLength": 1,
                        "title": "Text"
                    }
                },
                "type": "object",
                "required": [
                    "text"
                ],
                "title": "EmbedRequest"
            },
            "EmbedResponse": {
                "properties": {
                    "model": {
                        "type": "string",
                        "title": "Model"
                    },
                    "embedding": {
                        "items": {
                            "type": "number"
                        },
                        "type": "array",
                        "title": "Embedding"
                    }
                },
                "type": "object",
                "required": [
                    "model",
                    "embedding"
                ],
                "title": "EmbedResponse"
            },
            "GenerateDocRequest": {
                "properties": {
                    "customer": {
                        "type": "string",
                        "title": "Customer"
                    },
                    "subject": {
                        "type": "string",
                        "title": "Subject"
                    },
                    "quantity": {
                        "type": "integer",
                        "title": "Quantity"
                    },
                    "unit": {
                        "type": "string",
                        "title": "Unit"
                    },
                    "date": {
                        "type": "string",
                        "title": "Date"
                    },
                    "nmck": {
                        "type": "number",
                        "title": "Nmck"
                    },
                    "sources": {
                        "items": {
                            "$ref": "#/components/schemas/DocumentSource"
                        },
                        "type": "array",
                        "title": "Sources"
                    }
                },
                "type": "object",
                "required": [
                    "customer",
                    "subject",
                    "quantity",
                    "unit",
                    "date",
                    "nmck",
                    "sources"
                ],
                "title": "GenerateDocRequest"
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "LoginRequest": {
                "properties": {
                    "username": {
                        "type": "string",
                        "minLength": 1,
                        "title": "Username",
                        "examples": [
                            "demo"
                        ]
                    },
                    "password": {
                        "type": "string",
                        "minLength": 1,
                        "title": "Password",
                        "examples": [
                            "demo-password"
                        ]
                    }
                },
                "type": "object",
                "required": [
                    "username",
                    "password"
                ],
                "title": "LoginRequest"
            },
            "ParseJobRequest": {
                "properties": {
                    "source": {
                        "type": "string",
                        "title": "Source",
                        "description": "Data source identifier or URL to parse."
                    }
                },
                "type": "object",
                "required": [
                    "source"
                ],
                "title": "ParseJobRequest"
            },
            "ParseJobResponse": {
                "properties": {
                    "job_id": {
                        "type": "string",
                        "title": "Job Id"
                    },
                    "status": {
                        "type": "string",
                        "title": "Status",
                        "default": "queued"
                    }
                },
                "type": "object",
                "required": [
                    "job_id"
                ],
                "title": "ParseJobResponse"
            },
            "TokenResponse": {
                "properties": {
                    "access_token": {
                        "type": "string",
                        "title": "Access Token"
                    },
                    "token_type": {
                        "type": "string",
                        "title": "Token Type",
                        "default": "bearer"
                    }
                },
                "type": "object",
                "required": [
                    "access_token"
                ],
                "title": "TokenResponse"
            },
            "UserResponse": {
                "properties": {
                    "username": {
                        "type": "string",
                        "title": "Username"
                    },
                    "is_active": {
                        "type": "boolean",
                        "title": "Is Active",
                        "default": true
                    }
                },
                "type": "object",
                "required": [
                    "username"
                ],
                "title": "UserResponse"
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": {
                        "type": "string",
                        "title": "Message"
                    },
                    "type": {
                        "type": "string",
                        "title": "Error Type"
                    },
                    "input": {
                        "title": "Input"
                    },
                    "ctx": {
                        "type": "object",
                        "title": "Context"
                    }
                },
                "type": "object",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError"
            }
        },
        "securitySchemes": {
            "HTTPBearer": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    }
}